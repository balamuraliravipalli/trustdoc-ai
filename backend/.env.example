# Copy to .env and add your API key.
# ChatGPT Plus is separate from API billing; the API key needs platform credits.
OPENAI_API_KEY=replace_me
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Docker compose overrides this to http://qdrant:6333 for the backend container.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=trustdoc_chunks
DATABASE_URL=sqlite:///./trustdoc.db
UPLOAD_DIR=./data/uploads

MAX_CHUNK_WORDS=350
CHUNK_OVERLAP_WORDS=60
TOP_K=3
MIN_KEYWORD_SCORE=0.0

# Optional API-key protection for simple demos.
APP_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional demo role-based auth. Keep false for easiest local development.
AUTH_ENABLED=false
JWT_SECRET=change-this-before-deploying
DEMO_ADMIN_EMAIL=admin@trustdoc.local
DEMO_ADMIN_PASSWORD=admin123
DEMO_USER_EMAIL=user@trustdoc.local
DEMO_USER_PASSWORD=user123
TOKEN_EXPIRE_MINUTES=240

VITE_API_BASE_URL=http://localhost:8000
VITE_APP_API_KEY=
